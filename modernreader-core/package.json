{
  "name": "modernreader-core",
  "version": "1.0.0",
  "description": "ModernReader - Semantica 驅動的學術與知識生態系統",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\""
  },
  "keywords": [
    "semantica",
    "quantum",
    "ai",
    "academic",
    "arxiv",
    "podcast",
    "agent",
    "mcp"
  ],
  "author": "ModernReader Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "vitest": "^1.0.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0"
  },
  "dependencies": {}
}
